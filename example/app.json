{
  "name": "EaseExample",
  "displayName": "EaseExample",
  "expo": {
    "name": "EaseExample",
    "slug": "ease-example",
    "scheme": "ease-example",
    "version": "1.0.0",
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "platforms": [
